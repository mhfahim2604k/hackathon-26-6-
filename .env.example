# QueueStorm Investigator — environment variables
# Copy this file to .env and fill in real values locally. NEVER commit .env.

PORT=8000

# Optional: enable LLM-assisted customer_reply generation.
# Leave empty to use the deterministic rule-based generator only.
OPENAI_API_KEY=

# Optional: model identifier used when OPENAI_API_KEY is set.
# Default: gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# Logging
LOG_LEVEL=info