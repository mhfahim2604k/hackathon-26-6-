{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/**",
          "package.json",
          "tsconfig.json"
        ]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.ts" },
    { "src": "/analyze-ticket", "dest": "api/index.ts" },
    { "src": "/(.*)", "dest": "public/$1" }
  ],
  "env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info"
  }
}