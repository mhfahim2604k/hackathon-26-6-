{
  "name": "queuestorm-investigator",
  "version": "1.0.0",
  "description": "QueueStorm Investigator — internal AI copilot for digital finance support agents",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
