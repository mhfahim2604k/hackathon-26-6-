  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.0.4",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}